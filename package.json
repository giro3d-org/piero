{
    "name": "giro3d-sample-application",
    "version": "0.0.0",
    "private": true,
    "scripts": {
        "build": "vue-tsc && vite build",
        "format-eslint": "eslint . --fix --ignore-path .gitignore",
        "format-prettier": "prettier --write .",
        "format-markdownlint": "markdownlint . --fix --ignore-path .gitignore",
        "format": "npm run format-eslint && npm run format-prettier && npm run format-markdownlint",
        "lint-eslint": "eslint . --ignore-path .gitignore --max-warnings=0",
        "lint-prettier": "prettier --check .",
        "lint-markdownlint": "markdownlint . --ignore-path .gitignore",
        "lint": "npm run lint-eslint && npm run lint-prettier && npm run lint-markdownlint",
        "serve": "npm run build && vite preview",
        "start": "vite --port 8080",
        "test": "npm run lint",
        "prepare": "shx cp node_modules/web-ifc/web-ifc.wasm public/web-ifc.wasm && husky"
    },
    "dependencies": {
        "@giro3d/giro3d": "^0.33.1",
        "@loaders.gl/core": "^3.4.5",
        "@loaders.gl/csv": "^3.4.5",
        "@loaders.gl/geopackage": "^3.4.5",
        "@loaders.gl/las": "^3.4.5",
        "@loaders.gl/shapefile": "^3.4.5",
        "@popperjs/core": "^2.11.8",
        "@tarekraafat/autocomplete.js": "^10.2.7",
        "bootstrap": "^5.3.1",
        "bootstrap-icons": "^1.11.1",
        "camera-controls": "^2.7.0",
        "chart.js": "^3.9.1",
        "chroma-js": "^2.4.2",
        "cityjson-threejs-loader": "^0.4.0",
        "font-gis": "^1.0.5",
        "ol": "^8.2.0",
        "openbim-components": "^1.1.5",
        "pinia": "^2.1.6",
        "proj4": "^2.9.0",
        "shepherd.js": "^11.1.1",
        "shx": "^0.3.4",
        "three": "^0.160.1",
        "three.meshline": "^1.4.0",
        "vue": "^3.3.9",
        "web-ifc": "^0.0.44"
    },
    "devDependencies": {
        "@rushstack/eslint-patch": "^1.3.2",
        "@types/bootstrap": "^5.2.6",
        "@types/chroma-js": "^2.4.2",
        "@types/three": "^0.157.0",
        "@vitejs/plugin-vue": "^4.5.0",
        "@vitejs/plugin-vue-jsx": "^3.0.2",
        "@vue/eslint-config-prettier": "^8.0.0",
        "@vue/eslint-config-typescript": "^11.0.3",
        "@vue/test-utils": "^2.4.1",
        "@vue/tsconfig": "^0.4.0",
        "eslint": "^8.50.0",
        "eslint-plugin-vue": "^9.17.0",
        "husky": "^9.0.10",
        "jsdom": "^22.1.0",
        "lint-staged": "^15.2.1",
        "markdownlint": "^0.33.0",
        "markdownlint-cli": "^0.39.0",
        "prettier": "^3.0.0",
        "sass": "^1.65.1",
        "typescript": "^5.1.6",
        "vite": "^4.4.1",
        "vite-plugin-node-polyfills": "^0.16.0",
        "vitest": "^0.33.0",
        "vue-tsc": "^1.6.5"
    },
    "lint-staged": {
        "**/*.{ts,vue,js,jsx,cjs,mjs}": [
            "eslint",
            "prettier"
        ],
        "**/*.{json,jsonc}": [
            "prettier"
        ],
        "**/*.md": [
            "markdownlint",
            "prettier"
        ]
    }
}
