{
    "name": "piero",
    "type": "module",
    "version": "25.10.0",
    "workspaces": [
        "packages/*"
    ],
    "private": true,
    "overrides": {
        "three": "^0.170.0"
    },
    "scripts": {
        "apidoc:build": "typedoc",
        "app:build": "npm run copy-wasm && vite build",
        "app:dev": "npm run copy-wasm && vite --port 8080",
        "app:serve": "npm run app:build -- --base 'http://localhost:8080' && vite preview --port 8080",
        "copy-wasm": "shx cp node_modules/web-ifc/web-ifc.wasm public/web-ifc.wasm && shx cp node_modules/laz-perf/lib/laz-perf.wasm public/laz-perf.wasm",
        "format": "npm run format-eslint && npm run format-prettier && npm run format-markdownlint",
        "format-eslint": "eslint . --fix",
        "format-markdownlint": "markdownlint . --fix --ignore-path .gitignore",
        "format-prettier": "prettier --write .",
        "libs:build": "npm run build --workspaces --if-present",
        "libs:package": "npm run package --workspaces --if-present",
        "lint": "npm run lint:eslint && npm run lint:prettier && npm run lint:markdown",
        "lint:eslint": "eslint . --max-warnings=0",
        "lint:markdown": "markdownlint . --ignore-path .gitignore",
        "lint:prettier": "prettier --check .",
        "prepare": "husky",
        "site:build": "vitepress build site/doc",
        "site:dev": "vitepress dev site/doc",
        "site:preview": "vitepress preview site/doc",
        "test": "vitest",
        "typecheck": "npm run typecheck --workspaces --if-present"
    },
    "devDependencies": {
        "@commitlint/cli": "^19.8.1",
        "@commitlint/config-conventional": "^19.8.1",
        "@commitlint/cz-commitlint": "^19.8.1",
        "@rollup/plugin-node-resolve": "^16.0.1",
        "@rushstack/eslint-patch": "^1.7.2",
        "@types/bootstrap": "^5.2.10",
        "@types/chroma-js": "^2.4.4",
        "@types/geojson": "^7946.0.14",
        "@types/semver": "^7.7.1",
        "@types/three": "^0.170.0",
        "@vitejs/plugin-vue": "^5.2.4",
        "@vitejs/plugin-vue-jsx": "^4.2.0",
        "@vue/eslint-config-prettier": "^10.2.0",
        "@vue/eslint-config-typescript": "^14.5.1",
        "@vue/test-utils": "^2.4.4",
        "@vue/tsconfig": "^0.7.0",
        "canvas": "^3.2.1",
        "chokidar": "^5.0.0",
        "eslint": "^9.29.0",
        "eslint-plugin-import": "^2.31.0",
        "eslint-plugin-perfectionist": "^4.15.0",
        "eslint-plugin-tsdoc": "^0.4.0",
        "eslint-plugin-vue": "^10.2.0",
        "gray-matter": "^4.0.3",
        "husky": "^9.0.11",
        "jsdom": "^26.1.0",
        "lint-staged": "^16.1.2",
        "markdownlint": "^0.38.0",
        "markdownlint-cli": "^0.45.0",
        "prettier": "^3.2.5",
        "rollup-plugin-node-externals": "^8.1.2",
        "sass": "^1.89.2",
        "semver": "^7.7.2",
        "shx": "^0.3.4",
        "typedoc": "^0.28.17",
        "typedoc-plugin-markdown": "^4.10.0",
        "typedoc-plugin-zod": "^1.4.3",
        "typescript": "5.8.3",
        "vite": "^6.3.5",
        "vite-plugin-dts": "^4.5.4",
        "vite-plugin-node-polyfills": "^0.23.0",
        "vitepress": "^2.0.0-alpha.15",
        "vitest": "^3.2.4",
        "vitest-canvas-mock": "^1.1.3",
        "vue-tsc": "^3.0.6",
        "zod": "^4.1.11"
    },
    "lint-staged": {
        "**/*.{ts,vue,js,jsx,cjs,mjs}": [
            "eslint",
            "prettier"
        ],
        "**/*.{json,jsonc,css,scss,html}": [
            "prettier"
        ],
        "**/*.md": [
            "markdownlint",
            "prettier"
        ]
    },
    "config": {
        "commitizen": {
            "path": "@commitlint/cz-commitlint",
            "name": "cz_conventional_commits",
            "tag_format": "v$version"
        }
    }
}
