{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
        "composite": true,
        // We want to avoid exporting API implementations, and keep only API interfaces
        "stripInternal": true,

        "paths": {
            "@/*": ["./src/*"],
            "@giro3d/piero/*": ["./src/*"],
            "@giro3d/piero": ["./src"]
        }
    },
    "include": ["src", "../../env.d.ts"]
}
