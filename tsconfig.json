{
    "compilerOptions": {
        "target": "ES2022",
        "module": "esnext",
        "lib": ["ES2022", "DOM", "DOM.Iterable"],
        "skipLibCheck": true,
        "allowJs": true,
        "checkJs": true,

        /* Bundler mode */
        "moduleResolution": "bundler",
        "allowSyntheticDefaultImports": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "jsx": "preserve",
        "esModuleInterop": true,

        /* Linting */
        "strict": true,
        "noImplicitOverride": true,

        "paths": {
            "@giro3d/piero": ["./packages/piero/src"], // to access root index file implicitly
            "@giro3d/piero/*": ["./packages/piero/src/*"],
            "@giro3d/piero-plugin-cityjson": ["./packages/piero-plugin-cityjson/src"]
        }
    },
    "exclude": ["node_modules", "**/dist"],
    "include": ["*.ts", "build"],
    "references": [
        { "path": "./tsconfig.node.json" },
        { "path": "./packages/piero/tsconfig.json" },
        { "path": "./packages/piero-plugin-cityjson/tsconfig.json" }
    ]
}
