{
    "include": ["src/*.js", "src/**/*.js"],
    "compilerOptions": {
        "target": "es6",
        "allowJs": true,
        "checkJs": true,
        "moduleResolution": "node",
        "alwaysStrict": true,
        "strictNullChecks": false,
        "emitDeclarationOnly": true,
        "declaration": true,
        "removeComments": false
    }
  }
