{
    // "include": ["src/**/*.ts", "src/**/*.js"],
    "compilerOptions": {
        "target": "ES2015",
        "allowJs": true,
        "checkJs": true,
        "moduleResolution": "node",
        "alwaysStrict": true,
        "strictNullChecks": false,
        "emitDeclarationOnly": false,
        "declaration": true,
        "removeComments": false,
        "allowSyntheticDefaultImports": true,
    }
  }
