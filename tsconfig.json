{
    "compilerOptions": {
        "target": "ES2022",
        "module": "esnext",
        "lib": ["ES2022", "DOM", "DOM.Iterable"],
        "skipLibCheck": true,
        "allowJs": true,
        "checkJs": true,

        /* Bundler mode */
        "moduleResolution": "bundler",
        "allowSyntheticDefaultImports": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "jsx": "preserve",
        "esModuleInterop": true,

        /* Linting */
        "strict": true,

        "paths": {
            "@giro3d/piero": ["./packages/piero/src"], // to access root index file implicitly
            "@giro3d/piero/*": ["./packages/piero/src/*"],
            "@/*": ["./packages/piero/src/*"]
        }
    },
    "exclude": ["node_modules", "dist"],
    "references": [{ "path": "./tsconfig.node.json" }, { "path": "./packages/piero/tsconfig.json" }]
}
