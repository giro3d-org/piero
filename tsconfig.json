{
    // "include": ["src/**/*.ts", "src/**/*.js"],
    "compilerOptions": {
        "target": "ES2020",
        "module": "ES2020",
        "allowJs": true,
        "checkJs": true,
        "moduleResolution": "node",
        "alwaysStrict": true,
        "resolveJsonModule": true,
        "strictNullChecks": false,
        "emitDeclarationOnly": false,
        "declaration": true,
        "removeComments": false,
        "allowSyntheticDefaultImports": true,
        "paths": {
            "@/*": ["./src/*"]
          },
    }
  }
