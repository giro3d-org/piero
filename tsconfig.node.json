{
    "compilerOptions": {
        "strict": true,
        "composite": true,
        "skipLibCheck": true,
        "module": "ESNext",
        "target": "es2015",
        "lib": ["ES2015.Iterable"],
        "moduleResolution": "bundler",
        "allowSyntheticDefaultImports": true
    },
    "include": [
        "vite.config.ts",
        "vitest.config.ts",
        "packages/**/vite.config.ts",
        "build/**/*.ts",
        "build/**/*.mjs"
    ]
}
