# https://git-scm.com/docs/githooks#_prepare_commit_msg
COMMIT_MSG_FILE=$1
COMMIT_SOURCE=$2
SHA1=$3

# Source can be message, template, merge, squash, or commit (for git commit --amend)
if [ "${COMMIT_SOURCE}" = "commit" ]; then
  echo "Skipping prepare-commit-msg hook due to amend."
  exit 0
fi

# If we're in the middle of an interactive rebase, GIT_SEQUENCE_EDITOR will be set.
# We'll skip the hook in this case as well.
if [ -n "$GIT_SEQUENCE_EDITOR" ]; then
  echo "Skipping prepare-commit-msg hook due to rebase."
  exit 0
fi

# Only run commitizen if no commit message has already been provided.
if [ -z "${COMMIT_SOURCE-}" ]; then
    echo "No commit source has been provided. Commitizen will help you to write your commit message:"
    # By default git hooks are not interactive. exec < /dev/tty allows a users terminal to interact with commitizen.
    exec < /dev/tty && npx cz --hook || true
fi
